APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://llm-sun9d4d50ex0o5wu.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-max
DASHSCOPE_ENABLE_THINKING=false
DASHSCOPE_MAX_TOKENS=0
AZURE_FALLBACK_ENABLED=true
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_MAX_COMPLETION_TOKENS=16384

MONGO_URI=mongodb://user:password@host:27017/db?authSource=admin
MONGO_DB=your_db

REDIS_URL=redis://:password@host:6379/1
HISTORY_TTL_SECONDS=86400
HISTORY_MONGO_URI=mongodb://user:password@host:27017/db?authSource=admin
HISTORY_MONGO_DB=your_db
HISTORY_SESSION_COLLECTION=agent_chat_sessions
HISTORY_MESSAGE_COLLECTION=agent_chat_messages
HISTORY_PERSIST_MONGO=true
HISTORY_REDIS_REQUIRED=false

# 0 = 不限工具调用轮数（由模型自行停止结束）；>0 则为强制收尾上限
MAX_TOOL_ROUNDS=0
DEFAULT_TOOL_LIMIT=20
MAX_TOOL_ROWS=50
MAX_TOOL_CHARS=16000
MAX_TOOL_ESTIMATED_TOKENS=8000
MAX_REGEX_LENGTH=50
MAX_CONTENT_FIELD_CHARS=8000
MONGO_MAX_TIME_MS=5000

KEEP_LATEST_TOOL_MESSAGES=4
# 第一层：tool message 总 token 超此阈值才触发轻量剪枝，保留最近 KEEP_LATEST 个
TOOL_COMPACT_TOKEN_THRESHOLD=64000

# 第二层：会话级 LLM 摘要压缩
MODEL_MAX_INPUT_TOKENS=500000
COMPACT_TRIGGER_PCT=0.85
COMPACT_RECENT_PROTECT_TOKENS=8000
MIN_RECENT_TURNS=3
SUMMARY_MODEL=

# token 粗估系数：中文场景用 2（len // CHARS_PER_TOKEN）
CHARS_PER_TOKEN=2

LOG_LEVEL=INFO
LOG_DIR=logs

# CORS：前端直连
CORS_ORIGINS=http://localhost:3000
